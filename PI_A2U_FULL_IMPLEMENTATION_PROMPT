CREATE TABLE IF NOT EXISTS public.pi_a2u_transactions (
  id SERIAL PRIMARY KEY,
  uid TEXT NOT NULL,
  username TEXT,
  payment_id TEXT NOT NULL,
  amount NUMERIC NOT NULL DEFAULT 0.01,
